# Kode lokasi bin ini (lihat di dashboard > Kelola Bin)
BIN_CODE=B-XXXX

# URL backend (tanpa trailing slash)
API_BASE_URL=https://your-app.vercel.app

# Shared secret — harus sama dengan SCANNER_API_TOKEN di .env.local backend
SCANNER_API_TOKEN=change_me_to_a_random_secret

# Cooldown (detik) sebelum QR yang sama bisa di-scan ulang
COOLDOWN_SECONDS=5

# Kamera scanner = kamera BAWAAN laptop (untuk QR + buka pintu).
# Boleh angka indeks (0 = kamera pertama) ATAU path device stabil by-id.
# Cek pilihan: ls /dev/v4l/by-id/   (pakai yang berakhiran -video-index0)
CAMERA_INDEX=0

# Fitur tambahan
SOUND_ENABLED=true
SNAPSHOT_ENABLED=true
ANTI_PHONE_SCREEN=false

# Servo holybin: gerakkan servo (pin 12 & 27) lewat holybin saat absen berhasil
SERVO_ENABLED=true
# URL holybin api_server.py (laptop yang terhubung ke ESP32)
HOLYBIN_API_URL=http://localhost:5000
# Status absen yang memicu servo (pisahkan koma): ok = absen baru, info = sudah absen
SERVO_TRIGGER_ON=ok
